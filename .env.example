# Emergency Response Simulation - Environment Variables

# =============================================================================
# REQUIRED: Maptiler (3D Map Visualization)
# =============================================================================
# Get free API key from: https://cloud.maptiler.com/
# Free tier: 100,000 map loads/month, no payment info required
VITE_MAPTILER_KEY=your_maptiler_key_here

# =============================================================================
# REQUIRED: AWS Polly (TTS Audio Briefing)
# =============================================================================
# Get credentials from: https://console.aws.amazon.com/iam/
# Create IAM user with Polly permissions
# Free tier: 5 million characters/month for first 12 months
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your_aws_access_key_here
VITE_AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Optional: Polly voice configuration
VITE_AWS_POLLY_VOICE_ID=Joanna
VITE_AWS_POLLY_ENGINE=neural

# =============================================================================
# OPTIONAL: AWS Bedrock (AI Emergency Guidance)
# =============================================================================
# Uses same AWS credentials as Polly
# Available models:
# - us.amazon.nova-micro-v1:0 (fastest, cheapest)
# - us.amazon.nova-lite-v1:0 (balanced)
# - us.amazon.nova-pro-v1:0 (best quality)
AWS_BEDROCK_MODEL=us.amazon.nova-lite-v1:0

# =============================================================================
# Application Configuration
# =============================================================================
NODE_ENV=development
VITE_APP_TITLE=Emergency Response Simulation

# Simulation Settings
VITE_DEFAULT_CITY=zurich
VITE_DEFAULT_RADIUS=300
VITE_ESCALATION_TIMEOUT=30000
